# ══════════════════════════════════════════════
#  Python / Backend
# ══════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
ENV/

# ── Environment ──
.env
.env.local
.env.*.local

# ── Logs ──
*.log

# ══════════════════════════════════════════════
#  Data Pipeline (Generated Data)
# ══════════════════════════════════════════════
# SQLite databases & SQL dumps generated by data-pipeline scripts
data-pipeline/output/*.db
data-pipeline/output/*.sqlite
data-pipeline/output/*.sql

# Ground truth JSON (generated, can be recreated)
data-pipeline/output/ground_truth.json

# ══════════════════════════════════════════════
#  Backend Data (Runtime)
# ══════════════════════════════════════════════
backend/coordinator/data/*.json
!backend/coordinator/data/ground_truth.json
backend/coordinator/data/*.db
backend/site-a/data/*.db
backend/site-b/data/*.db

# Service log files (from start_services.py or manual runs)
backend/*.log
site-a.log
site-b.log
coordinator.log
frontend.log

# ══════════════════════════════════════════════
#  Node / Frontend
# ══════════════════════════════════════════════
frontend/node_modules/
frontend/dist/
frontend/.env*
frontend/.eslintcache
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ══════════════════════════════════════════════
#  Docker
# ══════════════════════════════════════════════
.docker-volumes/

# ══════════════════════════════════════════════
#  Documents / Reports (generated)
# ══════════════════════════════════════════════
*.docx
*.pptx

# ══════════════════════════════════════════════
#  OS / IDE
# ══════════════════════════════════════════════
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ══════════════════════════════════════════════
#  Temporary / Scratch Files
# ══════════════════════════════════════════════
*.tmp
*.temp
*.bak
*~
# Scratch/test scripts (root level only)
/check_*.py
/test_*.py

