# 1. Supabase Project 1 - Site A (DBLP) - Connection Pooler
DATABASE_URL_SITE_A=postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# 2. Supabase Project 2 - Site B (Semantic Scholar) - Connection Pooler
DATABASE_URL_SITE_B=postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# 3. Supabase Project 3 - Coordinator (Merge & Job Results) - Connection Pooler
DATABASE_URL_COORDINATOR=postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
